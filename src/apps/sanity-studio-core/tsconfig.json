{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@fundamentry/typescript-config/react",
  "compilerOptions": {
    "jsx": "preserve",
    "module": "preserve",
    "moduleDetection": "force",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "vite/client"
    ],
    "paths": {
      "@project/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src"
  ],
  "files": [
    "sanity.cli.ts",
    "sanity.config.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
